{
  // P5 (patch 0.63): TypeScript ครอบเฉพาะ src/ (โค้ดโมดูลใหม่) เท่านั้น —
  // index.html ตัวเก่า (global-scope monolith) ยังไม่ถูก typecheck จนกว่าจะ migrate ทีละแท็บ
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": []
  },
  "include": ["src"]
}
